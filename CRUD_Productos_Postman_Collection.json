          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"nombre\": \"Monitor 24 pulgadas\",\n    \"marca\": \"Samsung\",\n    \"categoria\": \"Electronica\",\n    \"precio\": 3500.50,\n    \"existencias\": 15\n}"

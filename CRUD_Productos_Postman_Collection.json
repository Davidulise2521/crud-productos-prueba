          "raw": "{\n    \"nombre\": \"Monitor 24 pulgadas Modificado\",\n    \"marca\": \"Samsung\",\n    \"categoria\": \"Electronica\",\n    \"precio\": 3600.00,\n    \"existencias\": 15\n}"
